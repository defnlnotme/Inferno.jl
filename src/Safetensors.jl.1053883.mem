        - # Helper function to squeeze middle dimension of 3D array
        - function squeeze_middle(arr::Array{Float32, 3})
        -     s = size(arr)
        -     if s[2] == 1
        -         return reshape(arr, s[1], s[3])
        -     else
        -         return dropdims(arr, dims=2)
        -     end
        - end
