        0             if haskey(token_to_id, bos_tok)
        0                 bos_id = token_to_id[bos_tok]
        -             end
        -         end
        -     end
        -     
        -     # Default EOS for Qwen
        0     if eos_id == -1
        -         eos_id = 248045  # <|im_end|>
