        - struct SafetensorsFile
        0     path::String
        -     metadata::Dict{String, Any}
        -     tensors::Dict{String, Tuple{Int, Int, Vector{Int}}}  # name -> (offset, dtype, shape)
        -     data::Vector{UInt8}
        - end
