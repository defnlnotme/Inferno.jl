        0     Tokenizer.BPETokenizer(
        -         token_to_id,
        -         id_to_token,
        -         [(split(m, ' ', limit=2)[1], split(m, ' ', limit=2)[2]) for m in merges if length(split(m, ' ', limit=2)) == 2],
        -         merge_priority,
        -         special_tokens,
        -         pretokenizer,
        -         bos_id,
        -         eos_id
        -     )
        - end
