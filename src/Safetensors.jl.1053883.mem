        - """
        - Parse safetensors file header and return tensor info.
        - """
        - function parse_safetensors(path::String)
        0     data = read(path)
        -     
        -     # First 8 bytes are header size (little-endian uint64)
        0     header_size = reinterpret(UInt64, data[1:8])[1]
        -     
        -     # Parse JSON header
        0     header_bytes = data[9:8+header_size]
        0     header = JSON3.read(String(header_bytes))
        -     
        -     # Extract tensor info
        0     tensors = Dict{String, Tuple{Int, Int, Vector{Int}}}()
        0     data_offset = 8 + header_size
        -     
        0     for (name_sym, info) in header
        0         name = String(name_sym)  # Convert Symbol to String
        0  if name == "__metadata__"
        -  continue
        -  end
        -  
        -  # Get tensor properties
        0  dtype_str = get(info, :dtype, "F32")
        0  dtype = if dtype_str == "F32"
        -  1
        0  elseif dtype_str == "F16"
        -  2
        0  elseif dtype_str == "BF16"
        -  3 # BF16
        -  else
        0  1 # Default to F32
        -  end
        0  shape = Int.(get(info, :shape, []))
        0  offsets = Int.(get(info, :data_offsets, [0, 0]))
        -         
        -         # Store offset relative to data section (add 1 for Julia 1-indexing)
        -         # The offsets in JSON are 0-indexed relative to data section start
        0         tensors[name] = (data_offset + offsets[1] + 1, dtype, shape)
        0     end
        -     
        0     metadata = get(header, "__metadata__", Dict{String, Any}())
        -     
        0     return SafetensorsFile(path, metadata, tensors, data)
        - end
        - 
        - """
        - Get tensor data from safetensors file.
        - """
        - function get_tensor(safetensors::SafetensorsFile, name::String)
        0  if !haskey(safetensors.tensors, name)
        0  return nothing
        -  end
        -  
        0  offset, dtype, shape = safetensors.tensors[name]
        0  num_elements = prod(shape)
        -  
        0  if dtype == 1 # F32
        0  bytes = safetensors.data[offset:offset + num_elements * 4 - 1]
        0  data = reinterpret(Float32, bytes)
        -  # Materialize the array before reshape
        0  data_vec = Vector{Float32}(data)
        -  # Safetensors stores row-major, Julia is column-major
        0  if length(shape) == 2
        0  return copy(reshape(data_vec, shape[2], shape[1])')
        0  elseif length(shape) == 3 && shape[2] == 1
        -  # 3D tensor with shape [C, 1, K] (like conv1d)
        -  # Safetensors stores as [C, K] in row-major
        -  # Need: reshape to (K, C) then transpose to (C, K)
        0  return copy(reshape(data_vec, shape[3], shape[1])')
        -  else
        0  return copy(reshape(data_vec, shape...))
        -  end
        0  elseif dtype == 2 # F16
        0  bytes = safetensors.data[offset:offset + num_elements * 2 - 1]
        0  data16 = reinterpret(Float16, bytes)
        0  data = Float32.(Vector{Float16}(data16))
        -  # Safetensors stores row-major, Julia is column-major
        0  if length(shape) == 2
        0  return copy(reshape(data, shape[2], shape[1])')
        0  elseif length(shape) == 3 && shape[2] == 1
        -  # 3D tensor with shape [C, 1, K] (like conv1d)
        0  return copy(reshape(data, shape[3], shape[1])')
        -  else
        0  return copy(reshape(data, shape...))
        -  end
        0  elseif dtype == 3 # BF16
        0  bytes = safetensors.data[offset:offset + num_elements * 2 - 1]
        -  # BF16 is stored as 16-bit values, need to convert to Float32
        -  # BF16 has same exponent format as F32, just truncated mantissa
        -  # To convert: reinterpret as UInt16, shift left 16 bits, reinterpret as Float32
        0  data_bf16 = reinterpret(UInt16, bytes)
        -  # Each BF16 value needs to become a Float32
        0  data_f32 = [reinterpret(Float32, UInt32(x) << 16) for x in data_bf16]
        -  # Safetensors stores data in row-major order, but Julia uses column-major.
        -  # We need to reshape and then transpose to get correct ordering.
        -  # For a 2D tensor with shape [rows, cols], the data is stored row-by-row.
        -  # In Julia, reshape(data, cols, rows)' gives the correct matrix.
        0  if length(shape) == 2
        0  return copy(reshape(data_f32, shape[2], shape[1])')
        0  elseif length(shape) == 3 && shape[2] == 1
        -  # 3D tensor with shape [C, 1, K] (like conv1d)
        -  # Safetensors stores as [C, K] in row-major
        -  # Need: reshape to (K, C) then transpose to (C, K)
        0  return copy(reshape(data_f32, shape[3], shape[1])')
        -  else
        0  return copy(reshape(data_f32, shape...))
        -  end
        -  else
        0  error("Unsupported dtype: $dtype")
        -  end
        - end
