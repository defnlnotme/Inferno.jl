        0         for (token_sym, id) in tokenizer_data[:model][:vocab]
        0             token_to_id[String(token_sym)] = id + 1
        0         end
        -     end
        -     
        0     vocab_size = length(token_to_id)
        0     id_to_token = Vector{String}(undef, vocab_size)
        0     for (token, id) in token_to_id
        0         id_to_token[id] = token
        0     end
        -     
        -     # Build merge priority
        0     merge_priority = Dict{Tuple{String, String}, Int}()
        0     for (i, m) in enumerate(merges)
        0         parts = split(m, ' ', limit=2)
        0         if length(parts) == 2
        0             merge_priority[(parts[1], parts[2])] = i
        -         end
        0     end
        -     
        -     # Get special tokens
        0     special_tokens = String[]
        0     if haskey(tokenizer_data, :added_tokens)
        0         added_tokens = tokenizer_data[:added_tokens]
        0         if isa(added_tokens, Dict) || isa(added_tokens, AbstractDict)
        0             for (id, info) in added_tokens
        0                 if isa(info, Dict) || isa(info, AbstractDict)
        0                     content = get(info, :content, "")
        -                 else
        -                     content = ""
        -                 end
        0                 if !in(content, special_tokens) && !isempty(content)
        0                     push!(special_tokens, content)
        -                 end
        0             end
        -         end
        -     end
        -     
        -     # Load tokenizer config for EOS/BOS
        0     tokenizer_config_path = joinpath(model_dir, "tokenizer_config.json")
        -     eos_id = -1
        -     bos_id = -1
        -     
        0     if isfile(tokenizer_config_path)
        0         tc = JSON3.read(read(tokenizer_config_path, String))
        0         if haskey(tc, :eos_token)
        0             eos_tok = tc[:eos_token]
        -             if isa(eos_tok, Dict)
        -                 eos_tok = String(get(eos_tok, :content, ""))
        -             end
        0             if haskey(token_to_id, eos_tok)
        0                 eos_id = token_to_id[eos_tok]
