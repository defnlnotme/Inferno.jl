        -         # Skip header line if present
        0         start_idx = startswith(merge_lines[1], "#") || !occursin(" ", merge_lines[1]) ? 2 : 1
        0         merges = merge_lines[start_idx:end]
        -     end
        -     
        -     # Build token_to_id and id_to_token
